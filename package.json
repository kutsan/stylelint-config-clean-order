{
  "name": "stylelint-config-clean-order",
  "version": "9.0.0",
  "description": "Order your styles with stylelint-order.",
  "keywords": [
    "stylelint",
    "stylelint-config",
    "stylelint-order",
    "property order",
    "css order"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kutsan/stylelint-config-clean-order.git"
  },
  "license": "MIT",
  "author": "Kutsan Kaplan <me@kutsan.dev> (https://kutsan.dev)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./error": {
      "types": "./dist/error.d.ts",
      "import": "./dist/error.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm run clean",
    "build": "tsc --project tsconfig.build.json",
    "changeset": "changeset",
    "check": "pnpm run check:lint && pnpm run check:types && pnpm run check:format",
    "check:format": "prettier --check .",
    "check:lint": "eslint --max-warnings=0",
    "check:types": "tsc",
    "clean": "rimraf ./dist",
    "format": "prettier --write --list-different .",
    "prepare": "node scripts/install-husky.ts",
    "release": "changeset publish",
    "test": "vitest",
    "version": "changeset version && pnpm install --no-frozen-lockfile && pnpm run format"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@kutsan/eslint-config": "^2.0.5",
    "@kutsan/prettier-config": "^1.3.0",
    "@kutsan/typescript-config": "^2.2.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.9.1",
    "csstype": "^3.2.3",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "rimraf": "^6.1.3",
    "stylelint": "^17.12.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "stylelint": ">=16",
    "stylelint-order": ">=6"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=26",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.4.0",
      "onFail": "warn"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
